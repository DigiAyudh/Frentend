# DigiAyudh Frontend - Environment Configuration
# Copy this file to .env and fill in the values for your deployment

# =======================
# API Configuration
# =======================
# Backend API URL - Required for production
# For local development with mock API, leave empty or comment out
VITE_API_URL=http://localhost:5000/api

# =======================
# Development Settings
# =======================
# Set to true for development mode features
NODE_ENV=development

# =======================
# Security Settings (Advanced)
# =======================
# Enable HTTPS only in production
VITE_ENABLE_HTTPS_ONLY=false

# Enable CSRF protection
VITE_ENABLE_CSRF_PROTECTION=true

# Enable XSS protection
VITE_ENABLE_XSS_PROTECTION=true

# =======================
# Token Configuration
# =======================
# Token storage keys (default: auth_token, refresh_token)
VITE_TOKEN_KEY=auth_token
VITE_REFRESH_TOKEN_KEY=refresh_token

# Token expiry check interval (milliseconds) - default: 60000
VITE_TOKEN_EXPIRY_CHECK_INTERVAL=60000

# Token refresh threshold (milliseconds) - default: 300000 (5 minutes)
VITE_TOKEN_REFRESH_THRESHOLD=300000

# =======================
# Session Configuration
# =======================
# Session timeout (milliseconds) - default: 1800000 (30 minutes)
VITE_SESSION_TIMEOUT=1800000

# Session warning time (milliseconds) - default: 1620000 (27 minutes)
VITE_SESSION_WARNING_TIME=1620000

# =======================
# Rate Limiting
# =======================
# Enable rate limiting
VITE_RATE_LIMIT_ENABLED=true

# Maximum requests allowed
VITE_RATE_LIMIT_REQUESTS=100

# Rate limit window (milliseconds) - default: 900000 (15 minutes)
VITE_RATE_LIMIT_WINDOW=900000

# =======================
# Feature Flags
# =======================
# Enable two-factor authentication
VITE_ENABLE_2FA=true

# Enable audit logs
VITE_ENABLE_AUDIT_LOGS=true

# Enable IP validation
VITE_ENABLE_IP_VALIDATION=true

# Enable device fingerprinting
VITE_ENABLE_DEVICE_FINGERPRINTING=false

# =======================
# Logging
# =======================
# Log level: debug, info, warn, error
VITE_LOG_LEVEL=info

# Enable analytics
VITE_ENABLE_ANALYTICS=false

# =======================
# API Endpoints (Optional - for reference)
# =======================
# These are automatically constructed from VITE_API_URL
# Only set these if you need custom endpoint URLs

# VITE_AUTH_ENDPOINT=/auth
# VITE_USERS_ENDPOINT=/users
# VITE_PROJECTS_ENDPOINT=/projects
# VITE_TASKS_ENDPOINT=/tasks
# VITE_INVOICES_ENDPOINT=/invoices

# =======================
# Third-Party Integrations (Future)
# =======================
# Sentry error tracking
# VITE_SENTRY_DSN=https://...

# Analytics
# VITE_GA_ID=G-...

# =======================
# Notes
# =======================
# 1. Never commit the .env file to version control
# 2. Use .env for local development
# 3. Use .env.production for production builds
# 4. Vercel dashboard for production environment variables
# 5. Keep sensitive data (API keys, tokens) secure
